{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Standard Renovate configuration for all repositories",
    "extends": [
        "config:recommended"
    ],
    "commitMessagePrefix": "chore(deps): ",
    "labels": [
        "dependencies"
    ],
    "packageRules": [
        {
            "matchManagers": ["maven"],
            "matchPackagePatterns": ["^net\\.kyori:"],
            "groupName": "kyori dependencies",
            "groupSlug": "kyori-deps"
        }
    ],
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0
}
